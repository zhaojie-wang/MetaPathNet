Package: MetaPathNet
Title: KEGG-Based Metabolic and Signaling Network Analysis for Systems Biology
Version: 0.99.1
Authors@R: c(
    person(
        "Zhaojie", "Wang",
        email = "zhaojie.wang@cnrs.fr",
        role = c("aut", "cre"),
